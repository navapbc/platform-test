# Python/FastAPI environment variables
HOST=localhost
PORT=3500
API_AUTH_INSECURE_SHARED_KEY=local-dev-key
LOG_FORMAT=human-readable
ENVIRONMENT=local
IMAGE_TAG=local

# AWS / BDA configuration
BDA_PROJECT_ARN=arn:aws:bedrock:us-east-1:123456789012:data-automation-project/example
BDA_PROFILE_ARN=arn:aws:bedrock:us-east-1:123456789012:data-automation-profile/us
BDA_REGION=us-east-1
DOCUMENTAI_DOCUMENT_METADATA_TABLE_NAME=documentai-metadata-local
DOCUMENTAI_DOCUMENT_METADATA_JOB_ID_INDEX_NAME=jobId-index
DOCUMENTAI_INPUT_LOCATION=s3://documentai-input-local/input
DOCUMENTAI_OUTPUT_LOCATION=s3://documentai-output-local/output
